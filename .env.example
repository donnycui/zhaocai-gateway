# 环境变量示例
# 复制此文件为 .env 并填入你的 API keys

# 网关配置
ZHAOCAI_PORT=8000
ZHAOCAI_HOST=0.0.0.0
ZHAOCAI_LOG_LEVEL=info

# AI Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
NVIDIA_API_KEY=nvapi-...
DASHSCOPE_API_KEY=sk-...
SILICONFLOW_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Cloudflare Tunnel Token（如果使用 docker-compose 中的 tunnel 服务）
# 在 Cloudflare Zero Trust 控制台创建 tunnel 时获取
CF_TUNNEL_TOKEN=eyJ...
