# Gateway runtime
ZHAOCAI_PORT=8000
ZHAOCAI_HOST=0.0.0.0
ZHAOCAI_LOG_LEVEL=info
ZHAOCAI_CONFIG=./config.yaml

# Control plane
# Must be replaced with a strong token before production start
ZHAOCAI_ADMIN_TOKEN=REPLACE_WITH_STRONG_ADMIN_TOKEN
ZHAOCAI_CONTROL_DB=sqlite:///./data/control_plane.db
# Optional but strongly recommended: enables API key encryption at rest (Fernet key)
ZHAOCAI_ENCRYPTION_KEY=
# Gateway routing source: config | control_plane | hybrid
ZHAOCAI_ROUTING_SOURCE=hybrid
# Control-plane routing sync interval (seconds)
ZHAOCAI_CONTROL_SYNC_INTERVAL_SECONDS=5

# Node config compile mode: direct | gateway
ZHAOCAI_NODE_PROVIDER_MODE=gateway
# Used when ZHAOCAI_NODE_PROVIDER_MODE=gateway
ZHAOCAI_NODE_GATEWAY_PROVIDER_ID=zhaocai-gateway
ZHAOCAI_NODE_GATEWAY_BASE_URL=http://raspberrypi.local:8000/v1
ZHAOCAI_NODE_GATEWAY_PROVIDER_TYPE=openai
ZHAOCAI_NODE_GATEWAY_AUTH_SCHEME=bearer
ZHAOCAI_NODE_GATEWAY_API_KEY=
ZHAOCAI_NODE_GATEWAY_EXTRA_HEADERS={}

# AI Provider API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
NVIDIA_API_KEY=nvapi-...
DASHSCOPE_API_KEY=sk-...
SILICONFLOW_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Cloudflare tunnel token (optional for docker-compose cloudflared service)
CF_TUNNEL_TOKEN=eyJ...
